# Copy to .env.local and fill in the placeholder values.
# Grab connection strings from Supabase:
#   Project Settings → Database → Connection string → Transaction pooler / Session pooler

# Runtime queries — Transaction pooler (port 6543). IPv4-safe.
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Migrations only — Session pooler (port 5432). Used by `prisma migrate`.
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-<REGION>.pooler.supabase.com:5432/postgres"

# 32+ byte random base64 string used to sign session JWTs.
# Generate with: openssl rand -base64 48
SESSION_SECRET="<RANDOM_BASE64>"

# First admin account, created on `npm run db:seed:admin`.
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="<choose-a-strong-password>"

# Google Places API key (server-side only). Used to power address autocomplete
# on the load forms. Create in GCP Console → APIs & Services, enable the
# "Places API (New)" SKU, and restrict the key to that single API. If unset,
# autocomplete falls back to plain text inputs (no breakage).
GOOGLE_PLACES_API_KEY=""

# --- Google Cloud Storage ----------------------------------------------------
# Used for storing load documents (rate confirmations, BOLs, etc.).
# Create a service account with the "Storage Object Admin" role on the bucket,
# download a JSON key, and base64-encode the file:
#   PowerShell:  [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes((Get-Content -Raw key.json)))
#   macOS/Linux: base64 -i key.json | tr -d '\n'
GCP_PROJECT_ID=""
GCS_BUCKET=""
GCP_SERVICE_ACCOUNT_JSON_B64=""

# --- AI extraction (New Load → From document) -------------------------------
# The same GCP service account is also used for Cloud Vision OCR. Enable the
# Vision API in the project (console.cloud.google.com/apis/library/vision.googleapis.com).
# Set up a GCS bucket lifecycle rule to auto-delete the "staging/" prefix after
# 1 day so abandoned uploads don't accumulate.
#
# OpenAI key used to convert OCR text into structured load fields (gpt-4o-mini).
OPENAI_API_KEY=""
