# Copy to .env.local and fill in the placeholder values.
# Grab connection strings from Supabase:
#   Project Settings → Database → Connection string → Transaction pooler / Session pooler

# Runtime queries — Transaction pooler (port 6543). IPv4-safe.
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Migrations only — Session pooler (port 5432). Used by `prisma migrate`.
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-<REGION>.pooler.supabase.com:5432/postgres"

# 32+ byte random base64 string used to sign session JWTs.
# Generate with: openssl rand -base64 48
SESSION_SECRET="<RANDOM_BASE64>"

# First admin account, created on `npm run db:seed:admin`.
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="<choose-a-strong-password>"
